@model StatisticsViewModel

@{
    ViewData["Title"] = "Statistics";
}

<style>
    .statistics-page {
        font-family: 'Comic Sans MS', 'Courier New', cursive;
        padding: 20px;
    }

    .statistics-page h2,
    .statistics-page h3 {
        font-family: 'Comic Sans MS', 'Courier New', cursive;
        margin-top: 20px;
        margin-bottom: 10px;
    }

    .statistics-page p,
    .statistics-page li {
        font-size: 15px;
        margin: 4px 0;
    }

    .statistics-page ul {
        list-style-type: disc;
        padding-left: 20px;
    }

    .statistics-page .highlight {
        font-weight: bold;
        @* color: darkblue; *@
    }

    .statistics-page .section {
        border: 1px dashed black;
        padding: 10px 15px;
        border-radius: 10px;
        margin-bottom: 20px;
        background-color: #fefefe;
    }

    .statistics-page .emotion-tag-block {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 8px;
    }

    .statistics-page .emotion-badge {
        padding: 6px 10px;
        border-radius: 15px;
        white-space: nowrap;
        font-family: 'Comic Sans MS','Courier New', cursive;
        border: 1px solid black;
        background-color: #f5f5f5;
        font-size: 14px;
        display: inline-block;
        margin: 4px;
    }
</style>

<div class="statistics-page">
    <h2>Statistics</h2>

    <div class="section">
        <p><span class="highlight">Total entries:</span> @Model.Stats.TotalRecords</p>
        <p><span class="highlight">Today:</span> @Model.Stats.RecordsToday</p>
        <p><span class="highlight">This week:</span> @Model.Stats.RecordsThisWeek</p>
        <p><span class="highlight">This month:</span> @Model.Stats.RecordsThisMonth</p>
    </div>

    <div class="section">
        <h3>Emotion Frequency</h3>
        <ul>
        @foreach (var pair in Model.Stats.EmotionCounts)
        {
            <li>@pair.Key: @pair.Value</li>
        }
        </ul>
        <p><strong>Top emotion this week:</strong> @Model.Stats.TopEmotionWeek</p>
        <p><strong>Top emotion this month:</strong> @Model.Stats.TopEmotionMonth</p>
    </div>

    <div class="section">
        <h3>Top 5 Emotions</h3>
        <div class="emotion-tag-block">
        @foreach (var emotion in Model.Stats.TopEmotions) {
            <div class="emotion-badge" style="background-color: @emotion.Color">#@emotion.Name</div>
        }
        </div>
    </div>

    <div class="section">
        <h3>Top 5 Tags</h3>
        <div class="emotion-tag-block">
        @foreach (var tag in Model.Stats.TopTags) {
            <div class="emotion-badge">#@tag.Name</div>
        }
        </div>
    </div>

    <div class="section">
        <h3>Emotion–Tag Correlation</h3>
        @foreach (var pair in Model.Stats.EmotionTagCorrelation)
        {
            <p>
                <span class="highlight" style="background-color: @pair.Key.Color; padding: 2px 6px; border-radius: 10px;">
                    @pair.Key.Name
                </span>:
            </p>
            <div class="emotion-tag-block">
                @foreach (var tag in pair.Value)
                {
                    <div class="emotion-badge">#@tag.Name</div>
                }
            </div>
        }
    </div>
</div>