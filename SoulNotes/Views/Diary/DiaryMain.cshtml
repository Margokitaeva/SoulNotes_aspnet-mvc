@{
    ViewData["Title"] = "Diary";
}

@model SoulNotes.Models.NewRecordViewModel


<style>
    .diary-page input[type="text"], textarea {
        width: 100%;
        padding: 8px;
        font-family: 'Comic Sans MS','Courier New', cursive;
        margin-bottom: 12px;
        border: 1px solid black;
        font-size: 15px;
    }

    .diary-page label {
        font-family: 'Comic Sans MS','Courier New', cursive;
        font-weight: bold;
        display: block;
        margin-top: 10px;
    }

    .diary-page .scroll-box {
        display: flex;
        overflow-x: auto;
        gap: 10px;
        margin: 8px 0;
    }

    .diary-page .tag, .emotion {
        padding: 6px 10px;
        border-radius: 15px;
        white-space: nowrap;
        font-family: 'Comic Sans MS','Courier New', cursive;
        cursor: pointer;
        border: 1px solid black;
        margin: 2px;
    }

    .diary-page .selected {
        outline: 2px solid black;
    }

    .diary-page button {
        font-family: 'Comic Sans MS', cursive;
        margin-top: 20px;
        font-size: 16px;
        padding: 8px 20px;
        cursor: pointer;
    }
</style>

<div class="diary-page">

    <h2 style="font-family: 'Comic Sans MS', cursive;">New record</h2>

    <form asp-action="DiaryMain" method="post" id="recordForm">
        <label>Title:</label>
        @if (ViewBag.TitleError != null)
        {
            <label style="color: red;">@ViewBag.TitleError</label>
        }
        <input type="text" name="Form.Title" placeholder="Write your title here" id="titleInput" value="@Model.Form.Title" />

        <label>Write something about how your feel...</label>
        <textarea name="Form.Description" rows="3" placeholder="Something interesting happened lately...">@Model.Form.Description</textarea>

        <label>Add your own emotion if you want and pick colour for it...</label>
        <div style="display: flex; gap: 10px; align-items: center;">
            <input type="text" name="Form.CustomEmotionName" placeholder="new emotion name"/>
            <input type="color" name="Form.CustomEmotionColor" value="#cccccc" />
            <button type="submit" name="AddType" value="emotion">Add</button>
        </div>

        <label>Choose emotion(s) that you feel:</label>
        <div class="scroll-box" id="emotionsBox">
            @foreach (var emotion in Model.Emotions)
            {
                <div class="emotion" style="background-color: @emotion.Color" data-id="@emotion.EmotionId">
                    #@emotion.Name
                </div>
            }
        </div>
        
        <label>Choose the strongest (primary) emotion:</label>
        @if (ViewBag.PrimaryEmotionError != null)
        {
            <label style="color: red;">@ViewBag.PrimaryEmotionError</label>
        }
        <div class="scroll-box" id="primaryEmotionBox">
            @foreach (var emotion in Model.Emotions) {
                <div class="emotion" style="background-color: @emotion.Color" data-id="@emotion.EmotionId">
                    #@emotion.Name
                </div>
            }
        </div>

        <label>Add your own tag if you want</label>
        <div style="display: flex; gap: 10px; align-items: center;">
            <input type="text" name="Form.CustomTagName" placeholder="#new tag name" />
            <button type="submit" name="addType" value="tag">Add</button>
        </div>

        <label>Choose tag(s) that assosiate width your situation:</label>
        <div class="scroll-box" id="tagsBox">
            @foreach (var tag in Model.Tags) {
                <div class="tag" data-id="@tag.TagId">#@tag.Name</div>
            }
        </div>

        <input type="hidden" name="Form.PrimaryEmotionId" id="primaryEmotionInput" value="@Model.Form.PrimaryEmotionId" />

        <div id="selectedEmotionsInputs">
            @if (Model.Form.SelectedEmotionsIds != null)
            {
                foreach (var emotionId in Model.Form.SelectedEmotionsIds)
                {
                    <input type="hidden" name="Form.SelectedEmotionsIds" value="@emotionId" />
                }
            }
        </div>

        <div id="selectedTagsInputs">
            @if (Model.Form.SelectedTagsIds != null)
            {
                foreach (var tagId in Model.Form.SelectedTagsIds)
                {
                    <input type="hidden" name="Form.SelectedTagsIds" value="@tagId" />
                }
            }
        </div>

        <label>Choose the date:</label>
        <input type="date" name="Form.RecordDate" value="@(Model.Form.RecordDate == default ? DateTime.Now.ToString("yyyy-MM-dd") : Model.Form.RecordDate.ToString("yyyy-MM-dd"))" />

        <div style="margin-top: 20px">
            <button type="submit">Save</button>
        </div>
        
    </form>
</div>

<script>
    const selectedEmotions = new Set();
    const selectedTags = new Set();
    const titleInput = document.getElementById('titleInput');
    let primaryEmotionId = null;

    document.querySelectorAll('#emotionsBox .emotion').forEach(el => {
        el.addEventListener('click', () => {
            const id = el.dataset.id;
            el.classList.toggle('selected');
            selectedEmotions.has(id) ? selectedEmotions.delete(id) : selectedEmotions.add(id);
        });
    });

    document.querySelectorAll('#primaryEmotionBox .emotion').forEach(el => {
        el.addEventListener('click', () => {
            document.querySelectorAll('#primaryEmotionBox .emotion').forEach(e => e.classList.remove('selected'));
            el.classList.add('selected');
            primaryEmotionId = el.dataset.id;
            document.getElementById('primaryEmotionInput').value = primaryEmotionId;
        });
    });

    document.querySelectorAll('#tagsBox .tag').forEach(el => {
        el.addEventListener('click', () => {
            const id = el.dataset.id;
            el.classList.toggle('selected');
            selectedTags.has(id) ? selectedTags.delete(id) : selectedTags.add(id);
        });
    });

    document.getElementById('recordForm').addEventListener('submit', (e) => {
        const clickedButton = document.activeElement;

        if (clickedButton.type === 'submit' && clickedButton.innerText === 'Save') {
            titleInput.required = true;
        }
        else {
            titleInput.required = false;
        }
            
        const emotionInputs = document.getElementById('selectedEmotionsInputs');
        const tagInputs = document.getElementById('selectedTagsInputs');
        emotionInputs.innerHTML = '';
        tagInputs.innerHTML = '';

        selectedEmotions.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'Form.SelectedEmotionsIds';
            input.value = id;
            emotionInputs.appendChild(input);
        });

        selectedTags.forEach(id => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'Form.SelectedTagsIds';
            input.value = id;
            tagInputs.appendChild(input);
        });
    });

    const initialSelectedEmotions = new Set(
        Array.from(document.querySelectorAll('#selectedEmotionsInputs input'))
              .map(input => input.value)
    );
    document.querySelectorAll('#emotionsBox .emotion').forEach(el => {
        const id = el.dataset.id;

        if (initialSelectedEmotions.has(id)) {
            el.classList.add('selected');
            selectedEmotions.add(id);
        }
    });

    const initialSelectedTags = new Set(
        Array.from(document.querySelectorAll('#selectedTagsInputs input'))
              .map(input => input.value)
    );
    document.querySelectorAll('#tagsBox .tag').forEach(el => {
        const id = el.dataset.id;
        if (initialSelectedTags.has(id)) {
            el.classList.add('selected');
            selectedTags.add(id);
        }
    });

    const currentPrimaryEmotionId = document.getElementById('primaryEmotionInput').value;
    console.log("PrimaryEmotionInput value:", currentPrimaryEmotionId);
    document.querySelectorAll('#primaryEmotionBox .emotion').forEach(el => {
        if (el.dataset.id === String(currentPrimaryEmotionId)) {
            el.classList.add('selected');
        }
    });
</script>

